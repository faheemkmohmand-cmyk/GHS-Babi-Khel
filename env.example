# ─── Supabase ───────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Cloudinary (for image uploads) ────────────────────────────────
# Get these from https://console.cloudinary.com/settings
# 1. VITE_CLOUDINARY_CLOUD_NAME  — found on your Cloudinary dashboard
# 2. VITE_CLOUDINARY_UPLOAD_PRESET — create one at Settings > Upload > Upload Presets
#    IMPORTANT: Set the preset to "Unsigned" so browser uploads work without an API secret
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# ─── Setup Checklist ───────────────────────────────────────────────
# [ ] Create these env vars in Vercel: Project Settings > Environment Variables
# [ ] In Cloudinary: ensure your upload preset is set to "Unsigned"
# [ ] Redeploy after adding env vars (Vercel > Deployments > Redeploy)

# ─── Plausible Analytics (privacy-friendly, GDPR compliant) ─────────
# Get started: https://plausible.io  (free 30-day trial)
# Self-host:   https://plausible.io/docs/self-hosting (free forever)
#
# Step 1: Sign up at plausible.io → "Add a website"
# Step 2: Enter your domain: ghsbabikhel.indevs.in
# Step 3: Copy the domain value below
# Step 4: Add to Vercel: Project Settings > Environment Variables > Redeploy
#
# Leave VITE_PLAUSIBLE_DOMAIN empty to disable analytics entirely.
VITE_PLAUSIBLE_DOMAIN=ghsbabikhel.indevs.in

# Only needed if you self-host Plausible. Leave blank for Plausible cloud.
# Example: https://plausible.yourserver.com/js/script.js
VITE_PLAUSIBLE_SRC=

# ─── BISE Peshawar Result Fallback ──────────────────────────────────
# When NO school result has been published by the admin (Manage Result),
# the homepage Results page falls back to BISE Peshawar's board result
# search. The page title in that mode is now pulled LIVE from
# cloud.bisep.edu.pk every hour via /api/bisep-proxy?mode=current — so
# when BISEP switches from "HSSC Annual-II 2025" to "SSC Annual-I 2026",
# your website reflects the change automatically within ~1 hour.
#
# This env var is now ONLY a fallback, used when:
#   • The /api/bisep-proxy?mode=current endpoint is unreachable, OR
#   • BISEP's homepage HTML structure changes and the scraper can't
#     parse the exam title any more.
#
# You can leave it at the default — it will only ever show if the live
# scraper fails. If BISEP's HTML structure changes, update the regex in
# BOTH api/bisep-proxy.js (fetchCurrentExam function) AND api/og.js
# (scrapeBisepCurrentExam function) — they're intentionally duplicated
# to stay within Vercel Pro's 12-function limit.
VITE_BISEP_EXAM_TITLE=HSSC Annual-II 2025

# ─── Z.AI GLM-4.5-Flash — Homepage AI Assistant ────────────────────
# Powers the floating "AI Assistant" button on the homepage.
# The chat is proxied through /api/ai-chat (serverless) so the key
# never reaches the browser. Both GLM-4.5-Flash and GLM-4.7-Flash are
# 100% free on Z.AI's API platform (generous free tier, no credit card).
#
# Step 1: Sign up at https://z.ai and create an API key
#         (or follow https://docs.z.ai/guides/llm/glm-4.7)
# Step 2: Add to Vercel: Project Settings > Environment Variables
#         Name:  ZAI_API_KEY
#         Value: <your-key>
# Step 3: Redeploy (Vercel > Deployments > Redeploy)
#
# ⚠️  Do NOT prefix with VITE_ — that would expose the key to browsers.
#     Keep it server-side only (used by api/ai-chat.ts).
ZAI_API_KEY=your-z-ai-api-key-here

# (Optional) Override the model. Defaults to "glm-4.5-flash" (fast + free).
# Other free options on Z.AI: "glm-4.7-flash" (slightly smarter, still free).
ZAI_MODEL=glm-4.5-flash
