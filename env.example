# ─── Supabase ───────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Cloudinary (for image uploads) ────────────────────────────────
# Get these from https://console.cloudinary.com/settings
# 1. VITE_CLOUDINARY_CLOUD_NAME  — found on your Cloudinary dashboard
# 2. VITE_CLOUDINARY_UPLOAD_PRESET — create one at Settings > Upload > Upload Presets
#    IMPORTANT: Set the preset to "Unsigned" so browser uploads work without an API secret
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# ─── Setup Checklist ───────────────────────────────────────────────
# [ ] Create these env vars in Vercel: Project Settings > Environment Variables
# [ ] Create "school-uploads" bucket in Supabase Storage (set to Public)
#     — This is the fallback if Cloudinary uploads fail on some networks
# [ ] In Cloudinary: ensure your upload preset is set to "Unsigned"
# [ ] Redeploy after adding env vars (Vercel > Deployments > Redeploy)
