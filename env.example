# ─── Supabase ───────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Cloudinary (for image uploads) ────────────────────────────────
# Get these from https://console.cloudinary.com/settings
# 1. VITE_CLOUDINARY_CLOUD_NAME  — found on your Cloudinary dashboard
# 2. VITE_CLOUDINARY_UPLOAD_PRESET — create one at Settings > Upload > Upload Presets
#    IMPORTANT: Set the preset to "Unsigned" so browser uploads work without an API secret
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# ─── Setup Checklist ───────────────────────────────────────────────
# [ ] Create these env vars in Vercel: Project Settings > Environment Variables
# [ ] In Cloudinary: ensure your upload preset is set to "Unsigned"
# [ ] Redeploy after adding env vars (Vercel > Deployments > Redeploy)

# ─── Plausible Analytics (privacy-friendly, GDPR compliant) ─────────
# Get started: https://plausible.io  (free 30-day trial)
# Self-host:   https://plausible.io/docs/self-hosting (free forever)
#
# Step 1: Sign up at plausible.io → "Add a website"
# Step 2: Enter your domain: ghsbabikhel.indevs.in
# Step 3: Copy the domain value below
# Step 4: Add to Vercel: Project Settings > Environment Variables > Redeploy
#
# Leave VITE_PLAUSIBLE_DOMAIN empty to disable analytics entirely.
VITE_PLAUSIBLE_DOMAIN=ghsbabikhel.indevs.in

# Only needed if you self-host Plausible. Leave blank for Plausible cloud.
# Example: https://plausible.yourserver.com/js/script.js
VITE_PLAUSIBLE_SRC=

# ─── BISE Peshawar Result Fallback ──────────────────────────────────
# When NO school result has been published by the admin (Manage Result),
# the homepage Results page falls back to BISE Peshawar's board result
# search. The page title in that mode shows the name of the current BISE
# exam (e.g. "Result - HSSC Annual-II 2025"). Update this env var in
# Vercel whenever BISE announces a new exam (SSC Annual-I, SSC Annual-II,
# HSSC Annual-I, HSSC Annual-II, etc.). If left blank, defaults to
# "HSSC Annual-II 2025".
VITE_BISEP_EXAM_TITLE=HSSC Annual-II 2025
